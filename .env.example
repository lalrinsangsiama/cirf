# CIL Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# SUPABASE (REQUIRED)
# Get these from your Supabase project settings
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# RAZORPAY (REQUIRED for payments)
# Get these from your Razorpay Dashboard
# https://dashboard.razorpay.com/app/keys
# ============================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ============================================
# EMAIL SERVICE (REQUIRED for contact/newsletter)
# Get these from Resend: https://resend.com
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# AI CONTENT GENERATION (OPTIONAL)
# For blog post generation in admin panel
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ============================================
# ANALYTICS (OPTIONAL)
# Get these from PostHog: https://posthog.com
# ============================================
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# SECURITY (REQUIRED in production)
# Used for CSRF token signing in middleware
# Falls back to NEXTAUTH_SECRET, then an insecure default
# ============================================
CSRF_SECRET=your-csrf-secret-here
# NEXTAUTH_SECRET=optional-fallback-for-csrf

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_SITE_URL=https://cil-framework.org
# REQUIRED in production — used for auth email redirect URLs
# Without this, confirmation emails will contain localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
