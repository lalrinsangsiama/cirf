# CIL Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# SUPABASE (REQUIRED)
# Get these from your Supabase project settings
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# EMAIL SERVICE (REQUIRED for contact/newsletter)
# Get these from Resend: https://resend.com
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# AI CONTENT GENERATION (OPTIONAL)
# For blog post generation in admin panel
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ============================================
# ANALYTICS (OPTIONAL)
# Get these from PostHog: https://posthog.com
# ============================================
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# SECURITY (REQUIRED in production)
# Used for CSRF token signing in middleware
# Falls back to NEXTAUTH_SECRET. In production, one of these MUST be set
# or the app will fail to start.
# Generate with: openssl rand -hex 32
# ============================================
CSRF_SECRET=your-csrf-secret-here
# NEXTAUTH_SECRET=optional-fallback-for-csrf

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_SITE_URL=https://culturalinnovationlab.org
# REQUIRED in production — used for auth email redirect URLs
# Without this, confirmation emails will contain localhost:3000
NEXT_PUBLIC_APP_URL=https://culturalinnovationlab.org
LOG_LEVEL=info
